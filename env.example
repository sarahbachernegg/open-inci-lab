/**
 * Local ingredient sample data and OCR parsing utilities for Open INCI Lab.
 *
 * This file is safe to commit: it contains no API keys, no environment values,
 * and no personal data. The ingredient descriptions are neutral MVP copy and
 * should not be treated as medical, dermatological, or regulatory advice.
 */
export type Ingredient = {
  id: number;
  inci_name: string;
  aliases: string[];
  short_description: string;
  long_description: string;
};

export type IngredientMatch = {
  input: string;
  normalizedInput: string;
  match: Ingredient | null;
};

