const STOP_AFTER_WORDS = [
  "directions",
  "usage",
  "warning",
  "warnings",
  "caution",
  "batch",
  "lot",
  "made in",
  "distributed by",
  "manufactured by",
  "use before",
  "best before",
  "barcode",
  "website",
  "www.",
  "http",
  // German label/footer terms are included so German packaging still parses well.
  "anwendung",
  "hinweise",
  "warnung",
  "kontakt",
  "hergestellt",
  "vertrieb",
];

const INGREDIENT_START_PATTERN =
  /\b(?:ingredients?|ingredient list|inci|inhaltsstoffe|zutaten)\b\s*[:\-–—]?\s*/i;

const ingredientIndex = new Map<string, Ingredient>();

for (const ingredient of mockIngredients) {
  for (const name of [ingredient.inci_name, ...ingredient.aliases]) {
    ingredientIndex.set(normalizeIngredient(name), ingredient);
  }
}

export function normalizeIngredient(value: string): string {
  return value
    .normalize("NFKD")
    .replace(/[\u0300-\u036f]/g, "")
    .replace(/ß/g, "ss")
    .toLowerCase()
    .replace(/[{}[\]()]/g, " ")
    .replace(/[^a-z0-9/+.\-\s]/g, " ")
    .replace(/\s+/g, " ")
    .trim();
}

function cleanCandidate(value: string): string {
  return value
    .replace(/\([^)]*\)/g, " ")
    .replace(/^\s*(?:and|or|und)\s+/i, "")
    .replace(/^[^a-zA-Z0-9]+|[^a-zA-Z0-9]+$/g, "")
    .replace(/\s+/g, " ")
    .trim();
}

function hasEnoughSignal(value: string): boolean {
  const normalized = normalizeIngredient(value);

  return (
    normalized.length >= 2 &&
    normalized.length <= 90 &&
    /[a-z]/.test(normalized) &&
    !/^\d+$/.test(normalized)
  );
}

function removeFooterSections(text: string): string {
  const lowerText = text.toLowerCase();
  const stopIndexes = STOP_AFTER_WORDS
    .map((word) => lowerText.indexOf(word))
    .filter((index) => index > 20);

  if (stopIndexes.length === 0) return text;

  return text.slice(0, Math.min(...stopIndexes));
}

export function extractIngredientsFromOcr(rawText: string): string[] {
  const cleaned = rawText
    .replace(/\r/g, "\n")
    .replace(/[•·]/g, ",")
    .replace(/\n{2,}/g, "\n")
    .trim();

  if (!cleaned) return [];

  const startMatch = cleaned.match(INGREDIENT_START_PATTERN);
  const ingredientBlock = startMatch
    ? cleaned.slice((startMatch.index ?? 0) + startMatch[0].length)
    : cleaned;

  const candidateText = removeFooterSections(ingredientBlock);
  const seen = new Set<string>();

  return candidateText
    .replace(/\n/g, " ")
    .split(/[,;|]/)
    .map(cleanCandidate)
    .filter(hasEnoughSignal)
    .filter((item) => {
      const normalized = normalizeIngredient(item);
      if (seen.has(normalized)) return false;
      seen.add(normalized);
      return true;
    });
}

function isIngredientMatch(input: string, ingredient: Ingredient): boolean {
  const normalizedInput = normalizeIngredient(input);
  const possibleNames = [ingredient.inci_name, ...ingredient.aliases].map(normalizeIngredient);

  return possibleNames.some((name) => {
    if (!normalizedInput || !name) return false;
    if (normalizedInput === name) return true;

    const inputWithoutSlashes = normalizedInput.replace(/\//g, " ");
    const nameWithoutSlashes = name.replace(/\//g, " ");

    return (
      inputWithoutSlashes === nameWithoutSlashes ||
      (name.length >= 5 && normalizedInput.includes(name)) ||
      (normalizedInput.length >= 5 && name.includes(normalizedInput))
    );
  });
}

export function matchIngredientsFromText(rawText: string): IngredientMatch[] {
  return extractIngredientsFromOcr(rawText).map((input) => {
    const normalizedInput = normalizeIngredient(input);

    return {
      input,
      normalizedInput,
      match:
        ingredientIndex.get(normalizedInput) ??
        mockIngredients.find((ingredient) => isIngredientMatch(input, ingredient)) ??
        null,
    };
  });
}
